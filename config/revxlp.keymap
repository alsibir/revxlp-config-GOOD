/* Краткое описание конфигурации:
 * - Слои: BASE_L (Base), NAV_L (Nav), NUM_L (Num), MED_L (Adjust, tri-layer), FUN_L (Media), MOU_L (Mouse), reserved_layer (отключён).
 * - Tri-layer: MED_L активируется при одновременной активности NUM_L и NAV_L.
 * - Tap-dance: shifty (одиночное нажатие — sticky Shift, двойное — caps_word).
 * - Переключение раскладки по D+F / J+K на базовом слое: отправка хоткеев ОС Alt+LShift (EN) / Alt+RShift (RU).
 * - GUI + Space реализовано без combos через sticky GUI на 2 секунды (исключает лаги на SPACE).
 *
 * Нумерация кнопок тамб-кластера (слева направо, по всей клавиатуре):
 * - Тамб-1, Тамб-2, Тамб-3 — три кнопки левого тамб-кластера (слева направо);
 * - Тамб-4, Тамб-5, Тамб-6 — три кнопки правого тамб-кластера (слева направо).
 * Примечание: в разметке bindings ниже каждая из 6 тамб-кнопок снабжена комментарием вида «Тамб-n».
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>

/* Примечание: использование &mmv/&msc/&mkp требует включения поддержки pointing (например, CONFIG_ZMK_POINTING=y).
 * Примечание: включение/отключение pointing изменяет HID-описатель; для BLE может потребоваться обновление HID-описателя на стороне хоста.
 */
#include <dt-bindings/zmk/pointing.h>

// -----------------------------------------------------------------------------
// Definitions
// -----------------------------------------------------------------------------

/* Для генерации прошивки с раскладкой Colemak закомментировать следующую строку (#define QWERTY_BASE). */
#define QWERTY_BASE

/* Индексы слоёв соответствуют порядку узлов внутри keymap (первый слой имеет индекс 0). */
#define BASE_L 0
#define NAV_L 1
#define NUM_L 2
#define MED_L 3
#define FUN_L 4
#define MOU_L 5

/* Унифицированные константы настройки combos */
#define COMBO_TIMEOUT_MS 120
#define COMBO_TIMEOUT_COMMAND_MS COMBO_TIMEOUT_MS

/* Параметры combos выбора раскладки (D+F, J+K). */
#define COMBO_TIMEOUT_LANG_SEL_MS 70
#define COMBO_IDLE_LANG_SEL_MS 250

#define COMBO_IDLE_SYMBOL_MS 150
#define COMBO_IDLE_COMMAND_MS 150
#define COMBO_IDLE_DANGER_MS 250

/* Унифицированные константы для tap-dance */
#define TAP_DANCE_TERM_MS 150

/* Позиции клавиш для combos переключения раскладки (зависят от выбранной базовой раскладки). */
#ifdef QWERTY_BASE
#define COMBO_LANG_EN_POS 15 16
#define COMBO_LANG_RU_POS 19 20
#else
#define COMBO_LANG_EN_POS 28 3
#define COMBO_LANG_RU_POS 6 30
#endif

/ {
    // -------------------------------------------------------------------------
    // Tap dances
    // -------------------------------------------------------------------------
    tap_dances {
        shifty: shift_caps_word {
            compatible = "zmk,behavior-tap-dance";
            display-name = "Shift+";
            #binding-cells = <0>;
            tapping-term-ms = <TAP_DANCE_TERM_MS>;
            bindings = <&sk LSHFT>, <&caps_word>;
        };
    };

    // -------------------------------------------------------------------------
    // Conditional layers (tri-layer)
    // -------------------------------------------------------------------------
    cond_layers {
        compatible = "zmk,conditional-layers";
        tri {
            if-layers = <NUM_L NAV_L>;
            then-layer = <MED_L>;
        };
    };

    // -------------------------------------------------------------------------
    // Macros
    // -------------------------------------------------------------------------
    macros {
        /* Опционально: GUI + Space (не используется в combos). */
        lang_tog: lang_tog {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms  = <25>;
            bindings
                = <&macro_press     &kp LGUI>
                , <&macro_wait_time 10>
                , <&macro_tap       &kp SPACE>
                , <&macro_wait_time 10>
                , <&macro_release   &kp LGUI>
                ;
        };

        /* Переключение раскладки через хоткеи ОС. */
        lang_en_os: lang_en_os {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms  = <25>;
            bindings
                = <&macro_press     &kp LALT>
                , <&macro_wait_time 10>
                , <&macro_tap       &kp LSHFT>
                , <&macro_wait_time 10>
                , <&macro_release   &kp LALT>
                ;
        };

        lang_ru_os: lang_ru_os {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms  = <25>;
            bindings
                = <&macro_press     &kp LALT>
                , <&macro_wait_time 10>
                , <&macro_tap       &kp RSHFT>
                , <&macro_wait_time 10>
                , <&macro_release   &kp LALT>
                ;
        };
    };

    // -------------------------------------------------------------------------
    // Combos
    // -------------------------------------------------------------------------
    combos {
        compatible = "zmk,combos";

        l_curly_bracket {
            timeout-ms = <COMBO_TIMEOUT_MS>;
            key-positions = <2 14>;
            bindings = <&kp LS(LBKT)>;
            layers = <NUM_L>;
        };

        r_curly_bracket {
            timeout-ms = <COMBO_TIMEOUT_MS>;
            key-positions = <4 16>;
            bindings = <&kp LS(RBKT)>;
            layers = <NUM_L>;
        };

        lbracket {
            timeout-ms = <COMBO_TIMEOUT_MS>;
            key-positions = <14 26>;
            bindings = <&kp LBKT>;
            layers = <NUM_L>;
        };

        rbracket {
            timeout-ms = <COMBO_TIMEOUT_MS>;
            key-positions = <16 28>;
            bindings = <&kp RBKT>;
            layers = <NUM_L>;
        };

        ques_mark_combo {
            timeout-ms = <COMBO_TIMEOUT_MS>;
            require-prior-idle-ms = <COMBO_IDLE_SYMBOL_MS>;
            key-positions = <21 33>;
            bindings = <&kp LS(FSLH)>;
        };

        bslash_combo {
            timeout-ms = <COMBO_TIMEOUT_MS>;
            require-prior-idle-ms = <COMBO_IDLE_SYMBOL_MS>;
            key-positions = <10 22>;
            bindings = <&kp BSLH>;
        };

        fslash_combo {
            timeout-ms = <COMBO_TIMEOUT_MS>;
            require-prior-idle-ms = <COMBO_IDLE_SYMBOL_MS>;
            key-positions = <22 34>;
            bindings = <&kp FSLH>;
        };

        bootloader_combo {
            timeout-ms = <COMBO_TIMEOUT_COMMAND_MS>;
            require-prior-idle-ms = <COMBO_IDLE_DANGER_MS>;
            key-positions = <5 6>;
            bindings = <&bootloader>;
            layers = <MED_L>;
        };

        gui_combo {
            timeout-ms = <COMBO_TIMEOUT_COMMAND_MS>;
            require-prior-idle-ms = <COMBO_IDLE_COMMAND_MS>;
            key-positions = <16 19>;
            bindings = <&kp LGUI>;
            layers = <MED_L>;
        };

        // ---------------------------------------------------------------------
        // Language switching combos (Base layer): D+F / J+K
        // ---------------------------------------------------------------------
        combo_lang_en {
            timeout-ms = <COMBO_TIMEOUT_LANG_SEL_MS>;
            require-prior-idle-ms = <COMBO_IDLE_LANG_SEL_MS>;
            key-positions = <COMBO_LANG_EN_POS>;
            layers = <BASE_L>;
            bindings = <&lang_en_os>;
        };

        combo_lang_ru {
            timeout-ms = <COMBO_TIMEOUT_LANG_SEL_MS>;
            require-prior-idle-ms = <COMBO_IDLE_LANG_SEL_MS>;
            key-positions = <COMBO_LANG_RU_POS>;
            layers = <BASE_L>;
            bindings = <&lang_ru_os>;
        };
    };

    // -------------------------------------------------------------------------
    // Custom behaviors
    // -------------------------------------------------------------------------
    behaviors {
        sk2s: sticky_key_2s {
            compatible = "zmk,behavior-sticky-key";
            #binding-cells = <1>;
            bindings = <&kp>;
            release-after-ms = <2000>;
            quick-release;
            lazy;
        };

        /* Поведение «mou_gui» назначено на Тамб-1 во всех слоях, где оно присутствует в тамб-кластере.
         * - удержание: &mo MOU_L
         * - нажатие:  sticky GUI (LGUI) на 2 секунды
         */
        mou_gui: mouse_layer_sticky_gui {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <0>;
            bindings = <&mo>, <&sk2s>;
        };
    };

    // -------------------------------------------------------------------------
    // Keymap
    // -------------------------------------------------------------------------
    keymap {
        compatible = "zmk,keymap";

        #ifdef QWERTY_BASE

        qwerty_layer {
            display-name = "Base";
            bindings = <
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &kp ESC          &kp Q            &kp W            &kp E             &kp R             &kp T                 &kp Y            &kp U            &kp I              &kp O             &kp P        &kp BSLH
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &mt LCTRL TAB    &kp A            &kp S            &kp D             &kp F             &kp G                 &kp H            &kp J            &kp K              &kp L             &kp SEMI     &kp SQT
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &kp LSHFT        &kp Z            &kp X            &kp C             &kp V             &kp B                 &kp N            &kp M            &kp COMMA          &kp DOT           &kp FSLH     &mt RALT GRAVE
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
//                                                    +-----------------+-----------------+-------------+       +----------------+----------------+------------------+
                                                        &mou_gui MOU_L LGUI /* Тамб-1 */  &mo NUM_L        /* Тамб-2 */  &lt NAV_L RET /* Тамб-3 */
                                                        &kp SPACE            /* Тамб-4 */  &kp BSPC        /* Тамб-5 */  &shifty       /* Тамб-6 */
//                                                    +-----------------+-----------------+-------------+       +----------------+----------------+------------------+
            >;
        };

        #else

        colemak_dhm_layer {
            display-name = "Base";
            bindings = <
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &kp ESC          &kp Q            &kp W            &kp F             &kp P             &kp B                 &kp J            &kp L            &kp U              &kp Y             &kp SQT      &kp BSLH
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &mt LCTRL TAB    &kp A            &kp R            &kp S             &kp T             &kp G                 &kp M            &kp N            &kp E              &kp I             &kp O        &kp SEMI
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &kp LSHFT        &kp Z            &kp X            &kp C             &kp D             &kp V                 &kp K            &kp H            &kp COMMA          &kp DOT           &kp FSLH     &mt RALT GRAVE
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
//                                                    +-----------------+-----------------+-------------+       +----------------+----------------+------------------+
                                                        &mou_gui MOU_L LGUI /* Тамб-1 */  &mo NUM_L        /* Тамб-2 */  &lt NAV_L RET /* Тамб-3 */
                                                        &kp SPACE            /* Тамб-4 */  &kp BSPC        /* Тамб-5 */  &shifty       /* Тамб-6 */
//                                                    +-----------------+-----------------+-------------+       +----------------+----------------+------------------+
            >;
        };

        #endif

        nav_layer {
            display-name = "Nav";
            bindings = <
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &kp LG(LS(N4))   &trans           &kp PG_UP        &kp UP_ARROW      &kp PG_DN         &kp HOME              &kp CARET        &kp PG_UP        &kp UP_ARROW       &kp PG_DN         &kp HOME     &kp LG(LS(N4))
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &trans           &trans           &kp LEFT_ARROW   &kp DOWN_ARROW    &kp RIGHT_ARROW   &kp END               &kp MINUS        &kp LEFT_ARROW   &kp DOWN_ARROW     &kp RIGHT_ARROW   &kp END      &trans
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &out OUT_TOG     &trans           &trans           &trans            &kp LC(LEFT)      &kp LC(RIGHT)         &kp LC(LEFT)     &kp LC(RIGHT)    &trans             &trans            &trans       &out OUT_TOG
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
//                                                    +-----------------+-----------------+-------------+       +----------------+----------------+------------------+
                                                        &mou_gui MOU_L LGUI /* Тамб-1 */  &mo NUM_L      /* Тамб-2 */  &trans         /* Тамб-3 */
                                                        &trans               /* Тамб-4 */  &trans        /* Тамб-5 */  &mo MED_L      /* Тамб-6 */
//                                                    +-----------------+-----------------+-------------+       +----------------+----------------+------------------+
            >;
        };

        num_layer {
            display-name = "Num";
            bindings = <
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &kp ESC          &kp N1           &kp N2           &kp N3            &kp N4            &kp N5                &kp N6           &kp N7           &kp N8             &kp N9            &kp N0       &kp GRAVE
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &trans           &kp EXCL         &kp AT           &kp HASH          &kp DLLR          &kp PRCNT             &kp CARET        &kp AMPS         &kp KP_MULTIPLY    &kp LPAR          &kp RPAR     &kp COLON
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &kp LSHFT        &kp N1           &kp KP_PLUS      &kp KP_MINUS      &kp LBRC          &kp LBKT              &kp RBKT         &kp RBRC         &kp KP_EQUAL       &kp UNDER         &trans       &trans
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
//                                                    +-----------------+-----------------+-------------+       +----------------+----------------+------------------+
                                                        &mou_gui MOU_L LGUI /* Тамб-1 */  &trans        /* Тамб-2 */  &lt NAV_L RET /* Тамб-3 */
                                                        &kp KP_N1           /* Тамб-4 */  &kp KP_N2     /* Тамб-5 */  &mo MED_L      /* Тамб-6 */
//                                                    +-----------------+-----------------+-------------+       +----------------+----------------+------------------+
            >;
        };

        adjust_layer {
            display-name = "Adjust";
            bindings = <
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &sys_reset       &trans           &trans           &trans            &trans            &trans                &kp C_VOL_UP     &trans           &trans             &trans            &trans       &sys_reset
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &bt BT_CLR       &bt BT_SEL 0     &bt BT_SEL 1     &bt BT_SEL 2      &bt BT_SEL 3      &bt BT_SEL 4          &kp C_VOL_DN     &trans           &trans             &trans            &trans       &trans
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &trans           &trans           &trans           &trans            &trans            &trans                &trans           &trans           &trans             &trans            &trans       &bootloader
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
//                                                    +-----------------+-----------------+-------------+       +----------------+----------------+------------------+
                                                        &trans              /* Тамб-1 */  &trans        /* Тамб-2 */  &mo FUN_L     /* Тамб-3 */
                                                        &trans              /* Тамб-4 */  &trans        /* Тамб-5 */  &trans        /* Тамб-6 */
//                                                    +-----------------+-----------------+-------------+       +----------------+----------------+------------------+
            >;
        };

        media_layer {
            display-name = "Media";
            bindings = <
// +----------------+----------------+----------------+----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &trans           &trans           &trans           &trans           &trans            &trans                &trans           &kp C_PREV       &kp C_VOL_DN       &kp C_VOL_UP      &kp C_NEXT   &trans
// +----------------+----------------+----------------+----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &trans           &trans           &trans           &trans           &trans            &trans                &trans           &trans           &trans             &trans            &trans       &trans
// +----------------+----------------+----------------+----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &trans           &trans           &trans           &trans           &trans            &trans                &trans           &trans           &kp C_PLAY_PAUSE   &kp C_MUTE        &trans       &trans
// +----------------+----------------+----------------+----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
//                                                    +-----------------+----------------+-------------+       +----------------+----------------+------------------+
                                                        &trans              /* Тамб-1 */  &trans        /* Тамб-2 */  &trans        /* Тамб-3 */
                                                        &trans              /* Тамб-4 */  &trans        /* Тамб-5 */  &trans        /* Тамб-6 */
//                                                    +-----------------+----------------+-------------+       +----------------+----------------+------------------+
            >;
        };

        mouse_layer {
            display-name = "Mouse";
            bindings = <
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &kp PG_UP        &kp HOME         &kp END          &kp PG_DN         &kp CAPS          &kp ESC               &kp LEFT_ARROW   &kp UP_ARROW     &kp DOWN_ARROW     &kp RIGHT_ARROW   &mkp LCLK    &mkp MCLK
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &kp LEFT_ARROW   &kp DOWN_ARROW   &kp UP_ARROW     &kp RIGHT_ARROW   &kp ENTER         &kp TAB               &mmv MOVE_LEFT   &mmv MOVE_DOWN   &mmv MOVE_UP       &mmv MOVE_RIGHT   &mkp RCLK    &kp PG_UP
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
     &mkp LCLK        &mkp MCLK        &mkp RCLK        &kp C_VOL_UP      &kp C_VOL_DN      &kp C_MUTE            &msc SCRL_LEFT   &msc SCRL_DOWN   &msc SCRL_UP       &msc SCRL_RIGHT   &kp PG_DN    &trans
// +----------------+----------------+----------------+-----------------+-----------------+-------------+       +----------------+----------------+------------------+-----------------+------------+--------------+
//                                                    +-----------------+-----------------+-------------+       +----------------+----------------+------------------+
                                                        &to BASE_L          /* Тамб-1 */  &to BASE_L   /* Тамб-2 */  &trans      /* Тамб-3 */
                                                        &mkp LCLK           /* Тамб-4 */  &mkp RCLK    /* Тамб-5 */  &mkp MCLK    /* Тамб-6 */
//                                                    +-----------------+-----------------+-------------+       +----------------+----------------+------------------+
            >;
        };

        reserved_layer {
            status = "disabled";
            display-name = "Reserved";
        };
    };
};
